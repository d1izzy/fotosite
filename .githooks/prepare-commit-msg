#!/bin/sh
# Strip Cursor co-author attribution from commit messages
if [ -n "$1" ] && [ -f "$1" ]; then
  sed -i.bak '/cursoragent@cursor\.com/d; /Co-authored-by: Cursor/d' "$1" 2>/dev/null || \
    sed -i '' '/cursoragent@cursor\.com/d; /Co-authored-by: Cursor/d' "$1"
  rm -f "$1.bak" 2>/dev/null || true
fi
